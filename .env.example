PORT=5000
NODE_ENV=development

# Use MongoDB Atlas free cluster or local MongoDB
MONGO_URI=mongodb+srv://YOUR_USERNAME:YOUR_PASSWORD@YOUR_CLUSTER.mongodb.net/url_shortener_assignment

# Use a long random value in real projects
JWT_ACCESS_SECRET=replace_with_a_long_random_secret
ACCESS_TOKEN_EXPIRES_IN=15m
REFRESH_TOKEN_DAYS=7

CLIENT_URL=http://localhost:5173
SERVER_URL=http://localhost:5000

# Optional SMTP settings. If these are empty, verification links print in backend terminal.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="URL Shortener <no-reply@example.com>"
